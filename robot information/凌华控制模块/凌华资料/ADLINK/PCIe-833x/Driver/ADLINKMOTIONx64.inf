;------------------------------------------------------------------------------
;Product pci8254_8 service add
;------------------------------------------------------------------------------
[DriverInstallx64_82548.NT.Services]
AddService=pci8254_8x64,2,DriverServicex64_pci8254_8

[DriverServicex64_pci8254_8]
ServiceType = 1
StartType   = 3
ErrorControl= 1
ServiceBinary  = %12%\pci8254_8x64.sys
LoadOrderGroup = Extended Base

[DriverInstallx64_82548.nt.hw]
AddReg=DriverHwAddRegx64_82548

[DriverHwAddRegx64_82548]

