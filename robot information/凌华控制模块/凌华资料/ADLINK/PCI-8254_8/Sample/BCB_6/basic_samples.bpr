    <IDLFILES value=""/>
    <IDLGENFILES value=""/>
    <DEFFILE value=""/>
    <RESDEPEN value="$(RESFILES) basic_samples_dlg.dfm dlg_version.dfm dlg_axis_monitor.dfm 
