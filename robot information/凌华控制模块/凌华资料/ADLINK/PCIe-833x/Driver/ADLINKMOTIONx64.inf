%String10%	=	DriverInstallx64_8158.NT,PCI\VEN_144A&DEV_8158&SUBSYS_51685168&REV_01
%String11%	=	DriverInstallx64_8158.NT,PCI\VEN_144A&DEV_8158&SUBSYS_2000144A&REV_70
%String12% 	= 	DriverInstallx64_8338.NT,PCI\VEN_144A&DEV_8338
%String12% 	= 	DriverInstallx64_8338.NT,PCI\VEN_144A&DEV_8338&SUBSYS_8338144A
