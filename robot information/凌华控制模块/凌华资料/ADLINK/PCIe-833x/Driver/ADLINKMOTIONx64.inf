[Version]
Signature="$CHICAGO$"
Class=MOTION
ClassGuid={711793D1-2694-11d6-A79E-0030640107EA}
Provider=%ADLINK%
DriverVer=11/07/2017,17.11.07.0
CatalogFile=ADLINKMOTIONx64.cat

[ClassInstall32]
AddReg = NuMotionClassAddReg

[NuMotionClassAddReg]
HKR,,,,"ADLINK Motion"
HKR,,Installer32,,"SMClassInstaller.dll,ClassInstaller"
HKR,,Icon,,"101"

[SourceDisksNames]   
1 = %%MotionInstall%%,,,     

[SourceDisksFiles]
pci8254_8x64.sys= 1   
APS168x64.sys	= 1    
MP_C154x64.sys	= 1
Pci8102x64.sys	= 1
PCI8154x64.sys	= 1
PCI8158x64.sys	= 1
PCIe8338x64.sys	= 1

[Manufacturer]
%ADLINK% = ADLINK_modelList, NTamd64

[ADLINK_modelList.NTamd64]
%String0%  	= 	DriverInstallx64_82548.NT,PCI\VEN_144A&DEV_8254
