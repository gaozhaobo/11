%String6%	=	DriverInstallx64_C154.NT,PCI\VEN_144A&DEV_C154&SUBSYS_C154144A&REV_03
%String6%	=	DriverInstallx64_C154.NT,PCI\VEN_144A&DEV_C154
%String7%	=	DriverInstallx64_8102.NT,PCI\VEN_144A&DEV_8102&SUBSYS_8102144A
