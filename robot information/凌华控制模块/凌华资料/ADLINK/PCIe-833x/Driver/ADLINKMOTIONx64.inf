DriverInstallx64_APS168.NT.Files = 12
DriverInstallx64_C154.NT.Files = 12
DriverInstallx64_8102.NT.Files = 12
DriverInstallx64_8154.NT.Files = 12
DriverInstallx64_8158.NT.Files = 12
DriverInstallx64_8338.NT.Files = 12
;------------------------------------------------------------------------------
;  Windows 64 Bit Edition
;------------------------------------------------------------------------------

[DriverInstallx64_82548.NT]
